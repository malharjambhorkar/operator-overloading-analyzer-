Grammar

    0 $accept: program $end

    1 program: items

    2 items: ε
    3      | items item

    4 item: class_def
    5     | main_def

    6 $@1: ε

    7 class_def: CLASS ID $@1 LBRACE members RBRACE SEMICOLON

    8 main_def: INT ID LPAREN RPAREN runtime_block

    9 members: ε
   10        | members member

   11 member: PUBLIC COLON

   12 $@2: ε

   13 member: INT $@2 member_after_type

   14 $@3: ε

   15 member: BOOL $@3 member_after_type

   16 $@4: ε

   17 member: VOID $@4 member_after_type

   18 $@5: ε

   19 member: ID $@5 id_started_member
   20       | SEMICOLON

   21 member_after_type: ID declaration_or_method_tail
   22                  | OPERATOR operator_symbol LPAREN param_decl RPAREN const_opt operator_tail

   23 id_started_member: LPAREN parameter_blob RPAREN ctor_initializer_opt block
   24                  | ID declaration_or_method_tail
   25                  | OPERATOR operator_symbol LPAREN param_decl RPAREN const_opt operator_tail

   26 declaration_or_method_tail: declaration_tail SEMICOLON
   27                           | LPAREN parameter_blob RPAREN const_opt method_tail

   28 declaration_tail: ε
   29                 | COMMA ID declaration_tail

   30 ctor_initializer_opt: ε
   31                     | COLON ctor_initializer_list

   32 ctor_initializer_list: ctor_initializer
   33                      | ctor_initializer_list COMMA ctor_initializer

   34 ctor_initializer: ID LPAREN argument_blob RPAREN

   35 method_tail: SEMICOLON
   36            | block

   37 const_opt: ε
   38          | CONST

   39 operator_tail: SEMICOLON
   40              | block

   41 param_decl: const_opt type ref_opt ID

   42 ref_opt: ε
   43        | AMP

   44 type: ID
   45     | INT
   46     | BOOL
   47     | VOID

   48 operator_symbol: PLUS
   49                | MINUS
   50                | MUL
   51                | DIV
   52                | EQ
   53                | LBRACKET RBRACKET

   54 parameter_blob: ε
   55               | parameter_blob parameter_blob_token

   56 parameter_blob_token: CONST
   57                     | ID
   58                     | NUMBER
   59                     | STRING_LITERAL
   60                     | INT
   61                     | BOOL
   62                     | VOID
   63                     | AMP
   64                     | ASSIGN
   65                     | COMMA
   66                     | MINUS

   67 argument_blob: ε
   68              | argument_blob argument_token

   69 argument_token: ID
   70               | NUMBER
   71               | STRING_LITERAL
   72               | INT
   73               | BOOL
   74               | VOID
   75               | COMMA
   76               | MINUS
   77               | PLUS
   78               | MUL
   79               | DIV
   80               | EQ
   81               | AMP
   82               | ASSIGN

   83 block: LBRACE block_items RBRACE

   84 block_items: ε
   85            | block_items block_item

   86 block_item: block
   87           | block_token

   88 block_token: ID
   89            | NUMBER
   90            | STRING_LITERAL
   91            | INT
   92            | BOOL
   93            | VOID
   94            | RETURN
   95            | CONST
   96            | PUBLIC
   97            | OPERATOR
   98            | PLUS
   99            | MINUS
  100            | MUL
  101            | DIV
  102            | EQ
  103            | LPAREN
  104            | RPAREN
  105            | SEMICOLON
  106            | LBRACKET
  107            | RBRACKET
  108            | COLON
  109            | COMMA
  110            | AMP
  111            | ASSIGN

  112 runtime_block: LBRACE runtime_items RBRACE

  113 runtime_items: ε
  114              | runtime_items runtime_item

  115 runtime_item: text_declaration
  116             | runtime_expression
  117             | RETURN NUMBER SEMICOLON
  118             | SEMICOLON

  119 text_declaration: ID ID LPAREN STRING_LITERAL RPAREN SEMICOLON

  120 runtime_expression: ID PLUS ID SEMICOLON
  121                   | ID MINUS ID SEMICOLON
  122                   | ID MUL NUMBER SEMICOLON
  123                   | ID EQ ID SEMICOLON
  124                   | ID LBRACKET NUMBER RBRACKET SEMICOLON


